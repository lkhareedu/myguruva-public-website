// MyGuruVa CRM — PostgreSQL schema (wn_* fields align with the app entity model)

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  // Azure App Service Linux runs Debian 11 (OpenSSL 3.x). Without this,
  // Prisma's query engine binary is missing on the container and the
  // server hangs at first DB query → "Container did not start in 230s".
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

// ─── CRM Authentication ────────────────────────────────────────────────────

model CrmUser {
  id         String   @id @default(uuid()) @db.Uuid
  email      String   @unique @db.VarChar(400)
  name       String?  @db.VarChar(400)
  password   String   @db.VarChar(200)
  role       String   @default("admin") @db.VarChar(100)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("crm_user")
}

// ─── Contact (system entity) ─────────────────────────────────────────────

model Contact {
  contactid     String   @id @default(uuid()) @db.Uuid
  fullname      String?  @db.VarChar(800)
  firstname     String?  @db.VarChar(400)
  lastname      String?  @db.VarChar(400)
  emailaddress1 String?  @db.VarChar(400)
  jobtitle      String?  @db.VarChar(400)
  // Comma-separated app role ids synced from CrmUser.role (for lookups / reporting).
  app_roles     String?  @db.VarChar(400)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("contact")
}

